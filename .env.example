# Create .env.local from this file. Never commit real secrets.

# --- AI (Gemini captions) ---
GEMINI_API_KEY=replace-with-a-new-key
GEMINI_MODEL=gemini-2.5-flash

# --- GenityBoost poster (Nano Banana) ---
GENTY_API_KEY=gnty:user01-xxxx
GENTY_BASE_URL=https://api.genityboost.site

# --- Auth ---
# Production WAJIB (min 16–32 chars)
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google OAuth (opsional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Database (opsional di lokal; WAJIB di production multi-instance) ---
# Tanpa baris ini → app pakai file JSON di data/
# Dengan Postgres (docker compose up -d):
# DATABASE_URL=postgresql://umkman:umkman@localhost:5432/umkman
#
# Lalu:
#   npx prisma db push
#   npm run db:seed
# DATABASE_URL=

# --- Media permanen (Vercel Blob) — WAJIB di production ---
# Buat store: vercel blob store add umkman-media
# Token otomatis / copy dari dashboard Storage → Blob
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# Tanpa token di Vercel, gambar upload/poster cuma di /tmp (bisa hilang).

# --- WhatsApp gateway GOWA (docker compose up -d gowa) ---
# Port 3100 agar tidak bentrok Next.js :3000
GOWA_BASE_URL=http://127.0.0.1:3100
# Harus sama dengan APP_BASIC_AUTH di docker-compose (user:pass)
GOWA_BASIC_AUTH=umkman:umkman-gowa-secret
# Harus sama dengan WHATSAPP_WEBHOOK_SECRET di docker-compose
GOWA_WEBHOOK_SECRET=umkman-webhook-secret

# Nomor WhatsApp CS (widget bubble di landing) — format 62…
NEXT_PUBLIC_SUPPORT_WA=

# --- Instagram Graph API (opsional — fallback global) ---
# Preferensi: hubungkan per usaha di Pengaturan → Instagram (multi-tenant).
# Env ini hanya fallback server jika usaha belum punya token sendiri.
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- Instagram Private API gateway (DEMO ONLY — ban risk) ---
# docker compose up -d aiograpi → http://localhost:8000/docs
AIOGRAPI_BASE_URL=http://127.0.0.1:8000

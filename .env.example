# Create .env.local from this file. Never commit real secrets.

# --- AI (Gemini captions) ---
GEMINI_API_KEY=replace-with-a-new-key
GEMINI_MODEL=gemini-2.5-flash

# --- GenityBoost poster (Nano Banana) ---
GENTY_API_KEY=gnty:user01-xxxx
GENTY_BASE_URL=https://api.genityboost.site

# --- Auth ---
# Production WAJIB (min 16–32 chars)
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google OAuth (opsional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Database (opsional di lokal; WAJIB di production multi-instance) ---
# Tanpa baris ini → app pakai file JSON di data/
# Dengan Postgres (docker compose up -d):
# DATABASE_URL=postgresql://umkman:umkman@localhost:5432/umkman
#
# Lalu:
#   npx prisma db push
#   npm run db:seed
# DATABASE_URL=
